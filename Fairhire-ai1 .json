    {
      "parameters": {
        "jsCode": "let bias_flags = $json.bias_flags || [];\n\nlet fairness_score = bias_flags.length > 0 ? 50 : 90;\n\nreturn [{\n  json: {\n    ...$json,\n    fairness_score,\n    bias_flags,\n    bias_status: bias_flags.length > 0 ? \"POTENTIAL BIAS\" : \"UNBIASED\",\n    bias_badge: fairness_score >= 80 ? \"🟢 Fair\" : \"🔴 Needs Review\"\n  }\n}];"
      },
